# ─── Peninsula Stack ─── copier vers .env et adapter ───

# ── PostgreSQL ──────────────────────────────────────────
PG_USER=peninsula
PG_PASSWORD=CHANGE_ME_pg_password
PG_DB=peninsula
PG_PORT=5432

# ── Peninsula API ───────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_random_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_random_64_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
API_PORT=4875
CORS_ORIGIN=*

# ── Admin auto-seed (premier lancement) ─────────────────
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_admin_password

# ── MySQL (PrestaShop) ──────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root
MYSQL_DATABASE=prestashop
MYSQL_USER=ps_user
MYSQL_PASSWORD=CHANGE_ME_mysql_password

# ── PrestaShop ──────────────────────────────────────────
PS_DOMAIN=localhost:8080
PS_PORT=8080
PS_DEV_MODE=0
PS_FOLDER_ADMIN=admin-peninsula
PS_ADMIN_MAIL=admin@peninsula.local
PS_ADMIN_PASSWD=CHANGE_ME_ps_admin

# ── phpMyAdmin (profil dev uniquement) ──────────────────
PMA_PORT=8081
